# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key

# Augustus Banking API key (Bearer token / JWT)
# Get from https://dashboard.augustus.com → Test Mode → Integration
AUGUSTUS_API_KEY=your_augustus_banking_key

# Augustus Payments API key (legacy Ivy API) — optional
# Enables checkout sessions, orders, refunds, bank search, and VOP
AUGUSTUS_PAYMENTS_API_KEY=your_augustus_payments_key

# Set to "production" to use live APIs (default: sandbox)
# AUGUSTUS_ENV=production
